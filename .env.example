# ==========================================
# MicroCMS Environment Variables
# ==========================================
# 1. Copy this file and rename it to `.env.local`
# 2. Fill in the values from your MicroCMS Dashboard
# 
# MicroCMS Setup Instructions:
# - Create an API named 'products' (List Type)
# - Add fields:
#   * title (Text field) -> "Product Name"
#   * sku (Text field) -> "SKU / Model"
#   * category (Select field) -> "Frames", "Components", "Apparel"
#   * basePrice (Number field) -> "Price"
#   * stock (Number field) -> "Current Stock"
#   * image (Image field) -> "Product Image"

VITE_MICROCMS_SERVICE_DOMAIN=your-service-domain
VITE_MICROCMS_API_KEY=your-api-key
